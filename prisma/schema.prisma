generator client {
  provider = "prisma-client-js"
}

// prisma/schema.prisma
datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
  // uncomment next line if you use Prisma <5.10
  // directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserStatus {
  active
  blocked
}

enum OtpPurpose {
  login
  signup
}

enum DeviceType {
  ios
  android
}

enum AddressLabel {
  home
  work
  other
}

enum CarType {
  sedan
  suv
  hatchback
  luxury
}

enum BookingStatus {
  pending
  confirmed
  staff_assigned
  in_progress
  completed
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum PaymentMethod {
  cash
  card
  wallet
}

enum StaffRole {
  admin
  manager
  staff
  calling_agent
}

// ─────────────────────────────────────────────
// Time slots
// ─────────────────────────────────────────────

model TimeSlotTemplate {
  id        String   @id @default(uuid())
  dayOfWeek Int      @map("day_of_week") // 0 = Sunday ... 6 = Saturday
  startTime String   @map("start_time") // "09:00"
  endTime   String   @map("end_time") // "10:00"
  capacity  Int      @default(1) // how many concurrent bookings this slot can take
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  bookings Booking[]

  @@unique([dayOfWeek, startTime, endTime])
  @@index([dayOfWeek])
  @@map("time_slot_templates")
}

// ─────────────────────────────────────────────
// Auth
// ─────────────────────────────────────────────

model User {
  id          String     @id @default(uuid())
  phoneNumber String     @unique @map("phone_number")
  name        String?
  email       String?
  isVerified  Boolean    @default(false) @map("is_verified")
  status      UserStatus @default(active)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  addresses     Address[]
  cars          Car[]
  bookings      Booking[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model OtpVerification {
  id          String     @id @default(uuid())
  phoneNumber String     @map("phone_number")
  otpHash     String     @map("otp_hash")
  purpose     OtpPurpose
  expiresAt   DateTime   @map("expires_at")
  isUsed      Boolean    @default(false) @map("is_used")
  attempts    Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([phoneNumber, purpose])
  @@map("otp_verifications")
}

model RefreshToken {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  tokenHash  String     @map("token_hash")
  deviceId   String     @map("device_id")
  deviceType DeviceType @map("device_type")
  expiresAt  DateTime   @map("expires_at")
  revoked    Boolean    @default(false)
  createdAt  DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// Profile
// ─────────────────────────────────────────────

model Address {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  label        AddressLabel @default(home)
  addressLine1 String       @map("address_line1")
  addressLine2 String?      @map("address_line2")
  city         String
  area         String?
  latitude     Decimal?     @db.Decimal(10, 7)
  longitude    Decimal?     @db.Decimal(10, 7)
  isDefault    Boolean      @default(false) @map("is_default")
  createdAt    DateTime     @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([userId])
  @@map("addresses")
}

// ─────────────────────────────────────────────
// Back office
// ─────────────────────────────────────────────

model StaffMember {
     id           String     @id @default(uuid())
     email        String     @unique
     passwordHash String     @map("password_hash")
     name         String
     phoneNumber  String?    @map("phone_number")
     role         StaffRole
     employeeId   String?    @unique @map("employee_id")
     status       UserStatus @default(active)
     createdAt    DateTime   @default(now()) @map("created_at")
     updatedAt    DateTime   @updatedAt @map("updated_at")

     refreshTokens StaffRefreshToken[]

     @@map("staff_members")
   }

   model StaffRefreshToken {
     id         String     @id @default(uuid())
     staffId    String     @map("staff_id")
     tokenHash  String     @map("token_hash")
     deviceId   String     @map("device_id")
     deviceType String     @map("device_type")
     expiresAt  DateTime   @map("expires_at")
     revoked    Boolean    @default(false)
     createdAt  DateTime   @default(now()) @map("created_at")

     staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

     @@index([staffId])
     @@map("staff_refresh_tokens")
   }

model Car {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  brand       String
  model       String
  year        Int?
  color       String?
  plateNumber String   @map("plate_number")
  carType     CarType  @map("car_type")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([userId])
  @@map("cars")
}

// ─────────────────────────────────────────────
// Services (self-referencing tree: category -> sub-category)
// ─────────────────────────────────────────────

model ServiceCategory {
  id          String   @id @default(uuid())
  parentId    String?  @map("parent_id")
  name        String
  description String?
  iconUrl     String?  @map("icon_url")
  imageUrl    String?  @map("image_url")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  parent   ServiceCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children ServiceCategory[] @relation("CategoryTree")

  pricing      ServicePricing[]
  bookingItems BookingItem[]

  @@index([parentId])
  @@map("service_categories")
}

model ServicePricing {
  id                String   @id @default(uuid())
  serviceCategoryId String   @map("service_category_id")
  carType           CarType? @map("car_type")
  price             Decimal  @db.Decimal(10, 2)
  weekendPrice      Decimal? @map("weekend_price") @db.Decimal(10, 2)
  durationMinutes   Int      @map("duration_minutes")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  serviceCategory ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)

  @@index([serviceCategoryId, carType])
  @@map("service_pricing")
}

// ─────────────────────────────────────────────
// Bookings
// ─────────────────────────────────────────────

model Booking {
  id                 String        @id @default(uuid())
  bookingNumber      String        @unique @map("booking_number")
  userId             String        @map("user_id")
  addressId          String        @map("address_id")
  carId              String        @map("car_id")
  timeSlotTemplateId String        @map("time_slot_template_id")
  status             BookingStatus @default(pending)
  scheduledDate      DateTime      @map("scheduled_date") @db.Date
  scheduledSlot      String        @map("scheduled_time_slot") // display snapshot, e.g. "09:00 - 10:00"
  subtotal           Decimal       @db.Decimal(10, 2)
  discount           Decimal       @default(0) @db.Decimal(10, 2)
  total              Decimal       @db.Decimal(10, 2)
  paymentStatus      PaymentStatus @default(pending) @map("payment_status")
  paymentMethod      PaymentMethod @map("payment_method")
  notes              String?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  user             User             @relation(fields: [userId], references: [id])
  address          Address          @relation(fields: [addressId], references: [id])
  car              Car              @relation(fields: [carId], references: [id])
  timeSlotTemplate TimeSlotTemplate @relation(fields: [timeSlotTemplateId], references: [id])
  items            BookingItem[]

  @@index([userId])
  @@index([status])
  @@index([scheduledDate])
  @@index([scheduledDate, timeSlotTemplateId])
  @@map("bookings")
}

model BookingItem {
  id                String   @id @default(uuid())
  bookingId         String   @map("booking_id")
  serviceCategoryId String   @map("service_category_id")
  price             Decimal  @db.Decimal(10, 2)
  durationMinutes   Int      @map("duration_minutes")

  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceCategory ServiceCategory @relation(fields: [serviceCategoryId], references: [id])

  @@index([bookingId])
  @@map("booking_items")
}
