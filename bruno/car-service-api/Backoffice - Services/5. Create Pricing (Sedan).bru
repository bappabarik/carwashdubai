meta {
  name: 5. Create Pricing (Sedan)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/backoffice/service-pricing
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{staffAccessToken}}
}

body:json {
  {
    "serviceCategoryId": "{{adminSubCategoryId}}",
    "carType": "sedan",
    "price": 85,
    "weekendPrice": 100,
    "durationMinutes": 30
  }
}

script:post-response {
  if (res.body.success) {
    bru.setVar("sedanPricingId", res.body.data.id);
  }
}